{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "The Black Pearl",
  "version": "0.1.3",
  "identifier": "com.matt.ghosty",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1423",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 23 },
        "backgroundColor": "#09090B"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/InfamousVague/TheBlackPearl/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRFMThBRUEyOTlBNEJGQzEKUldUQnY2U1pvcTRZVGk3dytlTjFwVDdhY2Y1Qmh1TzRpcjM1SVpSdkxlVG9PTG43YUZWNzVEVncK",
      "windows": { "installMode": "passive" }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "iOS": {
      "minimumSystemVersion": "15.0"
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "Entitlements.plist",
      "signingIdentity": "Developer ID Application: Matt Wisniewski (F6ZAL7ANAD)"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
