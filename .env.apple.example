# Apple signing + notarization credentials for GhostWire.
# Copy this to `.env.apple` (gitignored) and fill in real values — or just reuse
# the ones you already use for Libre.academy (same Apple account):
#
#   cp ../Libre.academy/.env.apple .env.apple
#
# These are account-level and shared across all your apps.

# Your Apple ID email (the developer account).
APPLE_ID=InfamousVagueRat@gmail.com

# App-specific password for notarytool — NOT your real Apple ID password.
# Generate at https://appleid.apple.com → Sign-In and Security → App-Specific Passwords.
APPLE_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Developer Team ID.
APPLE_TEAM_ID=F6ZAL7ANAD

# The code-signing certificate. Either the SHA-1 hash or this readable name:
APPLE_SIGNING_IDENTITY=Developer ID Application: Matt Wisniewski (F6ZAL7ANAD)
