# GhostWire social server runtime config.
# Copy to `.env` on the VPS (the deploy script syncs this file's values into the
# service EnvironmentFile). Never commit the real `.env`.

# Interface + port the Node process binds to. Keep it on localhost and let Nginx
# terminate TLS and reverse-proxy to it.
HOST=127.0.0.1
PORT=8787

# SQLite database file (accounts + follows + reports only — never content).
# Use an absolute path on the VPS, e.g. /opt/ghostwire-social/data/social.db
DB_PATH=./data/ghostwire-social.db

# Admin token guarding /v1/admin/* (bans, report review). Generate a long random
# value, e.g. `openssl rand -hex 32`. Leave blank to disable admin routes.
ADMIN_TOKEN=

# Public base URL clients hit (used in health output / logs only).
PUBLIC_URL=https://social.ghostwire.tv

# CORS origin allowed to call the REST API. Use the Tauri app origin or "*".
CORS_ORIGIN=*

# Session token lifetime (seconds). Default 7 days.
TOKEN_TTL_SECONDS=604800

# Auth challenge lifetime (seconds). Short on purpose.
CHALLENGE_TTL_SECONDS=120

# Max handle length (min is fixed at 3).
MAX_HANDLE_LEN=24
