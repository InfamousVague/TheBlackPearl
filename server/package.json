{
  "name": "ghostwire-social",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GhostWire social coordination server — identity, follows and live friend-to-friend search routing. Stores no content.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
