# Deploy target for the GhostWire social server.
# Copy to `deploy/.env` and fill in your VPS details. Used by deploy/deploy.sh.
# This file is gitignored.

# SSH login for the VPS (the same box that serves ghostwire.tv is fine).
DEPLOY_USER=youruser
DEPLOY_HOST=ghostwire.tv

# Optional: custom SSH port / identity file.
# DEPLOY_PORT=22
# DEPLOY_SSH_KEY=~/.ssh/id_ed25519

# Absolute install directory on the VPS.
DEPLOY_PATH=/opt/ghostwire-social

# systemd service name (must match the unit file you install).
SERVICE_NAME=ghostwire-social
